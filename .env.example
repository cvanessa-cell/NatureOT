# =============================================================================
# Nature OT Growth OS — environment template
# =============================================================================
# Setup:
#   1. Copy this file to `.env.local` (never commit `.env.local`).
#   2. Fill secrets from Supabase / Resend / Airtable / Zapier dashboards.
#   3. Apply DB: `npx supabase db push` or run migrations on your Supabase project.
#   4. Check locally: `npm run env:check`
#   5. Production: set the same keys in Vercel → Project → Settings → Environment Variables.
#
# Rollout order (recommended): verify Supabase + email → Airtable worker → Zapier relays.
# =============================================================================

# -----------------------------------------------------------------------------
# Core URLs
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Supabase (required for admin login, leads, consent storage)
# Browser needs NEXT_PUBLIC_* ; server can use SUPABASE_* aliases instead.
#
# Dashboard: https://supabase.com/dashboard → your project → Settings → API
#   - Project URL → NEXT_PUBLIC_SUPABASE_URL
#   - anon public → NEXT_PUBLIC_SUPABASE_ANON_KEY
#   - service_role → SUPABASE_SERVICE_ROLE_KEY (never expose to the browser)
# CLI (apply migrations in supabase/migrations): npm run supabase:link && npm run supabase:push
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional server-only aliases:
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Staff admin access (comma-separated). Also enforced via Supabase profiles/roles.
# -----------------------------------------------------------------------------
ADMIN_EMAILS=

# -----------------------------------------------------------------------------
# Email — Resend (https://resend.com)
# -----------------------------------------------------------------------------
EMAIL_DRY_RUN=true
RESEND_API_KEY=
EMAIL_FROM=

# Optional: verify Resend webhook signatures (api/webhooks/resend)
RESEND_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Zapier outbound relays (Catch Hooks or Zap webhook URLs)
# Enable only after URLs exist. Use dry-run while testing.
# -----------------------------------------------------------------------------
ZAPIER_ENABLED=false
ZAPIER_DRY_RUN=true
ZAPIER_WEBHOOK_SECRET=
ZAPIER_NEW_LEAD_WEBHOOK_URL=
ZAPIER_WAITLIST_WEBHOOK_URL=
ZAPIER_WORKSHOP_WEBHOOK_URL=
ZAPIER_BOOKING_WEBHOOK_URL=
ZAPIER_FEEDBACK_WEBHOOK_URL=
ZAPIER_UNSUBSCRIBE_WEBHOOK_URL=
ZAPIER_ERROR_WEBHOOK_URL=
ZAPIER_REFERRAL_WEBHOOK_URL=
ZAPIER_CONTENT_WEBHOOK_URL=
ZAPIER_SEO_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Airtable — PAT + base + table IDs (server-only; never NEXT_PUBLIC_)
# -----------------------------------------------------------------------------
AIRTABLE_SYNC_ENABLED=false
AIRTABLE_DRY_RUN=true
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

AIRTABLE_LEADS_TABLE_ID=
AIRTABLE_WAITLIST_TABLE_ID=
AIRTABLE_WORKSHOP_REGISTRATIONS_TABLE_ID=
AIRTABLE_REFERRAL_INQUIRIES_TABLE_ID=
AIRTABLE_REFERRAL_PARTNERS_TABLE_ID=
AIRTABLE_CONTENT_CALENDAR_TABLE_ID=
AIRTABLE_LOCAL_SEO_PAGES_TABLE_ID=
AIRTABLE_SEO_PAGES_TABLE_ID=
AIRTABLE_TESTIMONIALS_TABLE_ID=
# Workshops admin KPIs (some flows use this table id)
AIRTABLE_WORKSHOPS_TABLE_ID=

# Agent / MCP hints in UI (logic still requires credentials)
AGENT_AIRTABLE_ENABLED=true

# -----------------------------------------------------------------------------
# Hosted cron (Vercel Cron hits /api/cron/* — see vercel.json)
# -----------------------------------------------------------------------------
CRON_SECRET=
AIRTABLE_CRON_PROCESS_LIMIT=25

# -----------------------------------------------------------------------------
# Booking embed (Cal.com / Calendly public embed URL)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BOOKING_URL=
NEXT_PUBLIC_BOOKING_EMBED_URL=

# -----------------------------------------------------------------------------
# Parent guide delivery
# public_asset = serve from /public/guides/*.html (default)
# signed_url = Supabase Storage + service role (never expose bucket to client)
# -----------------------------------------------------------------------------
PARENT_GUIDE_DELIVERY_MODE=public_asset
PARENT_GUIDE_PUBLIC_ASSET_PATH=/guides/outdoor-sensory-activities-texas-kids.html
PARENT_GUIDE_ASSET_URL=
PARENT_GUIDE_STORAGE_BUCKET=guides
PARENT_GUIDE_STORAGE_PATH=outdoor-sensory-activities-texas-kids.pdf
PARENT_GUIDE_SIGNED_URL_EXPIRES_SECONDS=3600

# -----------------------------------------------------------------------------
# Optional — Stripe (payments)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Optional — Twilio SMS
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# -----------------------------------------------------------------------------
# Optional — OpenAI-compatible API (e.g. SEO drafts)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=

# -----------------------------------------------------------------------------
# Meta / Facebook measurement (Pixel + Conversions API)
# -----------------------------------------------------------------------------
# Create the Pixel in Meta Events Manager, then generate a long-lived token or
# system user token with access to that Pixel in Business settings.
NEXT_PUBLIC_META_PIXEL_ID=
META_ACCESS_TOKEN=
META_TEST_EVENT_CODE=
META_CAPI_ENABLED=false
META_CAPI_DRY_RUN=true

# =============================================================================
# GO LIVE — flip these after each integration is tested (never enable blind)
# =============================================================================
# EMAIL_DRY_RUN=false                    ← requires RESEND_API_KEY + EMAIL_FROM + domain verified
# ZAPIER_ENABLED=true                    ← requires webhook URLs + optional ZAPIER_WEBHOOK_SECRET
# ZAPIER_DRY_RUN=false
# AIRTABLE_SYNC_ENABLED=true             ← requires PAT + base + table IDs
# AIRTABLE_DRY_RUN=false
# META_CAPI_ENABLED=true                 ← requires NEXT_PUBLIC_META_PIXEL_ID + META_ACCESS_TOKEN
# META_CAPI_DRY_RUN=false
# =============================================================================
#
# Safety: do not send diagnosis narratives, PHI, insurance, medications,
# clinic notes, evaluations, therapy notes, documents, medical records, or
# school records via Airtable or Zapier.
